{
  "manifest_version": 3,
  "name": "PolyTranslate",
  "version": "2.0.0",
  "author": "Patrick Swanson",
  "description": "Privacy-first offline translation for PolyAI Agent Studio — powered by Bergamot WASM",
  "permissions": ["activeTab", "storage", "tabs", "offscreen"],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "action": {},
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.poly.ai/*"],
      "js": ["config.js", "translate.js", "content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "icons/*",
        "bergamot-translator-worker.js",
        "bergamot-translator-worker.wasm",
        "models/*",
        "installed-languages.json"
      ],
      "matches": ["https://*.poly.ai/*"]
    }
  ]
}
